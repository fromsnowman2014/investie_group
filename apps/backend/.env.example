# Enhanced News API Configuration
# Add these to your environment variables for better news coverage

# Existing APIs (you should already have these)
SERPAPI_API_KEY=your_serp_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# New API Keys for Enhanced News Service
# Get free keys from these services:

# NewsAPI (newsapi.org) - Free tier: 1000 requests/day
NEWS_API_KEY=your_newsapi_key_here

# Polygon.io (polygon.io) - Free tier: 5 calls/minute
POLYGON_API_KEY=your_polygon_key_here

# Finnhub (finnhub.io) - Free tier: 60 calls/minute
FINNHUB_API_KEY=your_finnhub_key_here

# Marketaux (marketaux.com) - Free tier: 100 calls/day
MARKETAUX_API_KEY=your_marketaux_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Other Configuration
NODE_ENV=development
PORT=3001
